# ── Database ──────────────────────────────────────────────────────────────────
# Railway injects this automatically when you add a Postgres plugin.
# For local dev, fill it in manually.
DATABASE_URL=postgresql://user:password@localhost:5432/grounders

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-secret-key-min-32-chars
JWT_EXPIRES_IN=30d

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# DEV_MODE=true returns the OTP in the response body (no SMS/email sent).
# Set to false in production and wire up Twilio/SendGrid below.
DEV_MODE=true

# Twilio (SMS OTP) — leave blank if using email only
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid (email OTP) — leave blank if using phone only
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ── Media storage (Cloudflare R2) ─────────────────────────────────────────────
# 1. cloudflare.com → R2 → Create bucket (e.g. "grounders-media")
# 2. R2 → Manage API Tokens → Create token with Object Read & Write
# 3. Enable public access on the bucket → copy the public URL
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=grounders-media
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Lock this to your domain in production. * is fine for development.
CORS_ORIGIN=*
