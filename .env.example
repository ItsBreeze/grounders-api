# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/grounders

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-min-32-chars
JWT_EXPIRES_IN=30d

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
DEV_MODE=true

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid (email OTP)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ── Media storage (Cloudflare R2) ─────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=grounders-media
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ── Firebase Cloud Messaging ──────────────────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key.
# Open the downloaded JSON and copy the three values below.
# Keep the literal \n sequences in FIREBASE_PRIVATE_KEY — the server replaces them.
# If any are blank, push is disabled and the rest of the API still works.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*
